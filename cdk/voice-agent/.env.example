# AWS Region — used for KVS and other AWS services
AWS_REGION=ca-central-1

# Bedrock region — Nova Sonic 2.0 endpoint
BEDROCK_REGION=us-east-1

# Session config (set by socket server via env vars)
SESSION_ID=default
VOICE_ID=
USER_ID=

# Patient config (set by socket server via env vars)
PATIENT_NAME=
PATIENT_PROMPT=
PATIENT_ID=
LLM_COMPLETION=false
EXTRA_SYSTEM_PROMPT=

# Database (set by socket server via env vars)
SM_DB_CREDENTIALS=
RDS_PROXY_ENDPOINT=

# NOTE: AWS credentials come from the ECS task role (deployed)
# or from `aws sso login` (local dev)
