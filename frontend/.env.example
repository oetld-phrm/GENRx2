# AWS Configuration
VITE_AWS_REGION=us-east-1

# Cognito Configuration
VITE_COGNITO_USER_POOL_ID=your-user-pool-id
VITE_COGNITO_USER_POOL_CLIENT_ID=your-client-id
VITE_IDENTITY_POOL_ID=your-identity-pool-id

# API Configuration
VITE_API_ENDPOINT=https://your-api-id.execute-api.us-east-1.amazonaws.com/prod/

# WebSocket Configuration
VITE_SOCKET_URL=wss://your-socket-url

# AppSync Configuration
VITE_APPSYNC_GRAPHQL_URL=https://your-appsync-url.appsync-api.us-east-1.amazonaws.com/graphql
